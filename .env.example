# Environment Variables - Example
# Copy this file to .env.local and fill in your actual API keys
# NEVER commit .env.local to GitHub - it contains sensitive data

# Groq API Key (AI Model)
# Get from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Pixabay API Key (Images)
# Get from: https://pixabay.com/api/
# Leave empty to use free tier without API key
PIXABAY_API_KEY=your_pixabay_api_key_here

# Convex Database
# Get from: https://convex.dev
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_DEPLOYMENT=your-deployment-id

# Arcjet Rate Limiting
# Get from: https://www.arcjet.com
ARCJET_KEY=your_arcjet_key_here
ARCJET_ENV=development

# Clerk Authentication
# Get from: https://clerk.com
# Create an app and get these values
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
CLERK_SECRET_KEY=your_clerk_secret_key

# Optional: Clerk Redirect URLs (for OAuth)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/